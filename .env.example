# Copy to .env and fill in values. ASP.NET Core maps nested config as Section__Key.

# Adaptive program switching (E3 / E4). Flat keys (as in ТЗ) or nested:
# ADAPTIVE_ERRORS_DOWNGRADE_THRESHOLD=8
# ADAPTIVE_ERRORS_UPGRADE_MAX=2
# AdaptiveErrors__DowngradeThreshold=8
# AdaptiveErrors__UpgradeMax=2

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD

Jwt__Key=YOUR_MINIMUM_32_CHAR_RANDOM_SECRET

Seed__AdminEmail=admin@example.com
Seed__AdminPassword=YOUR_STRONG_PASSWORD
